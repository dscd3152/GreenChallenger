<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/button_disabled" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/button_disabled" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#D8EEE7" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/green_primary" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/green_secondary" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="#B8D9CE" />
        </shape>
    </item>
</selector>
