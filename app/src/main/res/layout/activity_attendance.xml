<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/app_background"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="출석 체크"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <com.kizitonwose.calendarview.CalendarView
        android:id="@+id/materialCalendar"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_marginTop="10dp"
        app:cv_dayViewResource="@layout/day_item" />

    <ImageView
        android:id="@+id/treeImage"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="30dp"
        android:src="@drawable/tree_stage1"/>

    <TextView
        android:id="@+id/treeStatus"
        android:text="나무가 자라고 있어요 🌱"
        android:textColor="@color/green_primary"
        android:textSize="18sp"
        android:layout_marginTop="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/attendanceCountText"
        android:text="누적 출석: 0일"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:layout_marginTop="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- 🟢 버튼 추가된 부분 -->
    <Button
        android:id="@+id/btnCheckAttendance"
        android:layout_width="200dp"
        android:layout_height="55dp"
        android:text="출석 체크하기"
        android:textSize="18sp"
        android:textColor="@color/button_primary_text"
        android:background="@drawable/bg_primary_button"
        android:backgroundTint="@null"
        android:layout_marginTop="20dp"/>

</LinearLayout>
