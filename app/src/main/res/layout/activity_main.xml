<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026.05.02 (토)"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="환영합니다"
                android:textColor="@color/text_primary"
                android:textSize="25sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_hero_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <FrameLayout
                    android:layout_width="122dp"
                    android:layout_height="122dp"
                    android:background="@drawable/bg_image_bubble"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/treeHomeImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="성장 나무"
                        android:scaleType="fitCenter"
                        android:src="@drawable/tree_stage1" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtGrowthSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="씨앗 단계"
                        android:textColor="@color/green_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtPointSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="내 포인트: 0P"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_soft_chip"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="지구력 충전 중"
                        android:textColor="@color/green_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tipCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_tip_gradient"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="오늘의 친환경 팁"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtEcoTip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="텀블러를 챙기면 일회용 컵 사용을 줄일 수 있어요."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="오늘 할 일"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnAttendance"
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_gradient"
                    android:backgroundTint="@null"
                    android:text="출석 체크"
                    android:textColor="@color/button_primary_text"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnStartMission"
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_action_gradient"
                    android:backgroundTint="@null"
                    android:text="미션 인증"
                    android:textColor="@color/button_primary_text"
                    android:textSize="15sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnRewardAd"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_action_gradient"
                android:backgroundTint="@null"
                android:text="광고 보고 포인트 받기"
                android:textColor="@color/button_primary_text"
                android:textSize="15sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_bottom_bar"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <Button
            android:id="@+id/btnNavMission"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="미션"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnRanking"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="랭킹"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnRewardStore"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="상점"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnMyPage"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="마이"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
