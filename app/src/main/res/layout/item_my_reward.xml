<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="14dp">

    <ImageView
        android:id="@+id/imgMyReward"
        android:layout_width="92dp"
        android:layout_height="92dp"
        android:contentDescription="보관함 기프티콘 이미지"
        android:scaleType="centerCrop"
        android:src="@drawable/gifticon_starbucks_001" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtMyRewardName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="스타벅스 아메리카노"
            android:textColor="#263238"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMyRewardDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="테스트용 스타벅스 기프티콘"
            android:textColor="#6B756B"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtMyRewardDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="교환일: 2026-05-02 10:30:00"
            android:textColor="#6B756B"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtMyRewardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="상태: unused"
            android:textColor="#D84315"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnUseReward"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_primary_button"
            android:text="사용 완료"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
